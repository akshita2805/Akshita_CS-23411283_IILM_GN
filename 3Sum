class Solution(object):
    def threeSum(self, nums):
        n=len(nums)
        res=set()
        for i in range(n): 
            my_Set=set()
            for j in range(i+1,n):
                third=-(nums[i]+nums[j])
                if third in my_Set:
                    temp=[nums[i],nums[j],third]
                    temp.sort()
                    res.add(tuple(temp))
                my_Set.add(nums[j])
        return [list(ans)for ans in res]
